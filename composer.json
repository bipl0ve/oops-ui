{
  "name": "biplove/oops-ui",
  "version": "1.7",
  "description": "Beautiful, customizable error pages for Laravel applications with zero configuration required",
  "keywords": [
    "laravel",
    "error-pages",
    "error-handling",
    "404",
    "500",
    "exception-handling",
    "ui",
    "customizable",
    "responsive",
    "blade-templates"
  ],
  "homepage": "https://github.com/bipl0ve/oops-ui",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Biplove Singh",
      "email": "[EMAIL_ADDRESS]",
      "homepage": "https://github.com/bipl0ve",
      "role": "Developer"
    }
  ],
  "support": {
    "issues": "https://github.com/bipl0ve/oops-ui/issues",
    "source": "https://github.com/bipl0ve/oops-ui",
    "docs": "https://github.com/bipl0ve/oops-ui#readme"
  },
  "require": {
    "php": "^8.1|^8.2|^8.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0|^11.0",
    "orchestra/testbench": "^8.0|^9.0",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "Biplove\\OopsUi\\": "src/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Biplove\\OopsUi\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
    "format": "vendor/bin/php-cs-fixer fix --allow-risky=yes"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Biplove\\OopsUi\\OopsUiServiceProvider"
      ],
      "aliases": {
        "OopsUi": "Biplove\\OopsUi\\Facades\\OopsUi"
      }
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "preferred-install": "dist"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}